{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "skipLibCheck": true,
        "incremental": true,
        "tsBuildInfoFile": ".tsbuildinfo",
        "types": ["react", "react-native"],
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
    "exclude": ["node_modules", "android", "ios", "dist", "build"]
}
